{
  "name": "zstylemasterfin.zstylemasterfin",
  "version": "0.0.1",
  "private": true,
  "sapux": true,
  "sapuxLayer": "CUSTOMER_BASE",
  "description": "",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "scripts": {
    "start": "fiori run --open \"test/flpSandbox.html?sap-client=120&sap-ui-xx-viewCache=false#fe-lrop\"",
    "start-local": "fiori run --config ./ui5-local.yaml --open \"test/flpSandbox.html?sap-client=120&sap-ui-xx-viewCache=false#fe-lrop\"",
    "start-noflp": "fiori run --open \"index.html?sap-client=120&sap-ui-xx-viewCache=false\"",
    "start-variants-management": "fiori run --open \"preview.html?sap-client=120&sap-ui-xx-viewCache=false&fiori-tools-rta-mode=true&sap-ui-rta-skip-flex-validation=true#preview-app\"",
    "build": "ui5 build -a --clean-dest --include-task=generateCachebusterInfo",
    "deploy": "fiori verify",
    "deploy-config": "fiori add deploy-config",
    "start-mock": "fiori run --config ./ui5-mock.yaml --open \"test/flpSandbox.html?sap-client=120&sap-ui-xx-viewCache=false#fe-lrop\"",
    "suite-tests": "fiori run --open \"test/testsuite.qunit.html\"",
    "int-tests": "fiori run --open \"test/integration/opaTests.qunit.html\"",
    "lint": "eslint ./"
  },
  "devDependencies": {
    "@ui5/cli": "^4.0.0",
    "@sap/ux-ui5-tooling": "1",
    "rimraf": "6.0.1",
    "@sap-ux/ui5-middleware-fe-mockserver": "2",
    "@sap-ux/eslint-plugin-fiori-tools": "^10.0.0",
    "eslint": "^10"
  }
}
